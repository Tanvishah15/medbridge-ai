# Copy these keys into Streamlit Cloud → App settings → Secrets (TOML).
# Do NOT commit real values. Use flat keys so config.py can read them.

AZURE_AI_PROJECT_ENDPOINT = "https://YOUR-PROJECT.services.ai.azure.com/api/projects/YOUR-PROJECT"
AZURE_AI_MODEL_DEPLOYMENT = "gpt-4.1-mini"
AZURE_AI_MODEL_DEPLOYMENT_FAST = "gpt-4.1-mini"
FOUNDRY_IQ_KB_NAME = "medbridge-medical-kb"
AZURE_SEARCH_ENDPOINT = "https://YOUR-SEARCH.search.windows.net"
FOUNDRY_MCP_CONNECTION_NAME = "medbridge-kb-mcp-connection"

# Required on Streamlit Cloud (service principal — Azure CLI login is not available)
AZURE_TENANT_ID = "your-tenant-id"
AZURE_CLIENT_ID = "your-app-client-id"
AZURE_CLIENT_SECRET = "your-client-secret"
